# LoreHub Environment Variables Example
# Copy this file to .env.local and fill in your actual values
# IMPORTANT: .env.local is in .gitignore - never commit it!

# Bungie API Configuration
VITE_BUNGIE_API_KEY=your-actual-api-key-here

# OAuth Configuration (for server.js)
BUNGIE_CLIENT_ID=your-client-id-here
BUNGIE_CLIENT_SECRET=your-client-secret-here
BUNGIE_REDIRECT_URI=http://localhost:8000/auth/callback

# HTTPS Certificate Passphrase (for local dev server)
HTTPS_PFX_PASSPHRASE=your-passphrase-here

# Application Environment
VITE_APP_ENV=development
VITE_APP_DEBUG=true

# Logging Level
VITE_LOG_LEVEL=debug

# Cache Configuration
VITE_CACHE_DURATION=3600000

# API Configuration
VITE_API_BASE_URL=https://www.bungie.net/Platform
VITE_API_TIMEOUT=30000
VITE_API_MAX_RETRIES=3

# Feature Flags
VITE_FEATURE_SEARCH=true
VITE_FEATURE_FILTER=true
VITE_FEATURE_MODAL=true
VITE_FEATURE_CACHE=true

# UI Configuration
VITE_ITEMS_PER_PAGE=12
VITE_ANIMATION_DURATION=300

# Server Configuration (if using backend)
VITE_BACKEND_URL=http://localhost:3000
VITE_API_PROXY=false
